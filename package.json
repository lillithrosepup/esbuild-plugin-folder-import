{
  "name": "esbuild-plugin-folder-import",
  "displayName": "Esbuild Plugin Folder Import",
  "version": "1.0.1",
  "description": "An esbuild plugin that imports all files in a folder from a wildcard path with an explicit extension.",
  "type": "commonjs",
  "types": "dist/index.d.ts",
  "homepage": "https://github.com/lillithrosepup/esbuild-plugin-folder-import",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lillithrosepup/esbuild-plugin-folder-import.git"
  },
  "bugs": {
    "url": "https://github.com/lillithrosepup/esbuild-plugin-folder-import/issues"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup"
  },
  "keywords": [
    "esbuild-plugin"
  ],
  "author": "",
  "peerDependencies": {
    "esbuild": "0.28.1"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^24.13.3",
    "eslint": "^9.39.5",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@11.13.0+sha512.88d94724d8f2e6c186744a5584c6e59ecac869ec7ba15e9cb4cd628e8dc7066820b2481d8ee3b51ea8da323a7378068aa58c556a3720d32b7c20a051d088363a"
}
